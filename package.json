{
  "name": "farm-market-battle",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "deploy:cloudflare": "vinext deploy --name taiwan-stock-farm",
    "start": "vinext start",
    "test": "tsx --test tests/market.test.ts tests/hydration.test.ts && node --test tests/rendered-html.test.mjs tests/ios-source.test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "ios:add": "node --env-file-if-exists=.env.local scripts/ios-command.mjs add",
    "ios:sync": "node --env-file-if-exists=.env.local scripts/ios-command.mjs sync",
    "ios:open": "node scripts/ios-command.mjs open",
    "ios:run": "node --env-file-if-exists=.env.local scripts/ios-command.mjs run"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "drizzle-orm": "0.45.2",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
